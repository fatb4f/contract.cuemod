{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/workspace.projects.v1.schema.json",
  "title": "Adapter-neutral workspace project contexts",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "contractVersion",
    "srcRoot",
    "contractRoot",
    "projects"
  ],
  "properties": {
    "version": {
      "const": "workspace.projects.v1"
    },
    "contractVersion": {
      "type": "string"
    },
    "srcRoot": {
      "type": "string",
      "pattern": "^/"
    },
    "contractRoot": {
      "type": "string",
      "pattern": "^/"
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/project"
      }
    }
  },
  "$defs": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "root",
        "kind",
        "intent",
        "editor",
        "commands",
        "env",
        "adapters"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "label": {
          "type": "string"
        },
        "root": {
          "type": "string",
          "pattern": "^/"
        },
        "kind": {
          "enum": [
            "contract",
            "dotfiles",
            "learning",
            "project"
          ]
        },
        "intent": {
          "type": "string"
        },
        "editor": {
          "enum": [
            "nvim",
            "helix"
          ]
        },
        "commands": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "adapters": {
          "type": "object",
          "additionalProperties": {
            "type": "object"
          }
        }
      }
    }
  }
}
