{
  "schema": "agent.search-policy.v1",
  "version": "agent.search-policy.v1",
  "backend": "rg",
  "result_limit": {
    "min": 1,
    "max": 1000
  },
  "path": {
    "absolute_forbidden": true,
    "parent_escape_forbidden": true,
    "expansion_requires_projection_root": true
  },
  "terms": {
    "non_empty": true,
    "source": "request",
    "allow_regex": false
  }
}
