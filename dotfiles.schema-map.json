{
  "schema": "contract.cuemod.semantic-provider.schema-map.v0",
  "name": "dotfiles",
  "targetRepo": "fatb4f/dotfiles",
  "providerCatalogue": "fatb4f/dotfiles:.codex/plugins/agent-context-resolver/generated/provider_inventory.json",
  "providers": [
    {
      "id": "df:provider/codex-cli",
      "kind": "codex-cli",
      "protocol": "agent-runtime",
      "authority": "bounded-patch-executor",
      "runtime": false,
      "callable": false,
      "capabilities": ["targeted-read", "apply-patch", "targeted-validation", "commit-summary"]
    },
    {
      "id": "df:provider/cue-rg",
      "kind": "cue-rg",
      "protocol": "mcp-tool",
      "authority": "bounded-text-evidence",
      "runtime": false,
      "callable": false,
      "capabilities": ["search", "evidence"]
    },
    {
      "id": "df:provider/cue-lsp",
      "kind": "cue-lsp",
      "protocol": "lsp-over-mcp",
      "authority": "cue-graph",
      "runtime": true,
      "callable": true,
      "capabilities": ["definition", "references", "hover", "diagnostics", "documentSymbols", "workspaceSymbols", "validate", "evidence"],
      "mcp": {
        "serverID": "df:mcp/cue-lsp",
        "transport": "stdio",
        "adapter": "lsp-over-mcp",
        "toolPrefix": "cue_lsp",
        "tools": {
          "definition": "cue_lsp.definition",
          "references": "cue_lsp.references",
          "hover": "cue_lsp.hover",
          "diagnostics": "cue_lsp.diagnostics",
          "documentSymbols": "cue_lsp.document_symbols",
          "workspaceSymbols": "cue_lsp.workspace_symbols",
          "validate": "cue_lsp.validate",
          "evidence": "cue_lsp.evidence"
        }
      }
    },
    {
      "id": "df:provider/lua-lsp",
      "kind": "lua-lsp",
      "protocol": "lsp-over-mcp",
      "authority": "lua-implementation",
      "runtime": true,
      "callable": true,
      "capabilities": ["definition", "references", "hover", "diagnostics", "documentSymbols", "workspaceSymbols", "evidence"],
      "mcp": {
        "serverID": "df:mcp/lua-lsp",
        "transport": "stdio",
        "adapter": "lsp-over-mcp",
        "toolPrefix": "lua_lsp",
        "tools": {
          "definition": "lua_lsp.definition",
          "references": "lua_lsp.references",
          "hover": "lua_lsp.hover",
          "diagnostics": "lua_lsp.diagnostics",
          "documentSymbols": "lua_lsp.document_symbols",
          "workspaceSymbols": "lua_lsp.workspace_symbols",
          "evidence": "lua_lsp.evidence"
        }
      }
    },
    {
      "id": "df:provider/wezterm-types",
      "kind": "wezterm-types",
      "protocol": "lua-lsp-library",
      "authority": "wezterm-lua-type-surface",
      "runtime": false,
      "callable": false,
      "upstream": "DrKJeff16/wezterm-types",
      "capabilities": ["type-annotations", "completion-surface", "diagnostic-context", "hover-context"]
    },
    {
      "id": "df:provider/chezmoi",
      "kind": "chezmoi",
      "protocol": "mcp-tool",
      "authority": "deployment-provenance",
      "runtime": false,
      "callable": false,
      "capabilities": []
    }
  ],
  "semanticSurfaces": {
    "dotfiles.workspace-ide": {
      "authority": "bounded-workflow-doc",
      "files": [".github/WORKSPACE_IDE_VERIFICATION.md"],
      "providerIDs": ["df:provider/cue-rg"]
    },
    "dotfiles.wezterm-lua": {
      "authority": "lua-implementation",
      "files": ["chezmoi/private_dot_config/wezterm/**"],
      "providerIDs": ["df:provider/lua-lsp", "df:provider/wezterm-types", "df:provider/cue-rg"]
    },
    "dotfiles.nvim-workflow": {
      "authority": "lua-implementation",
      "files": ["chezmoi/private_dot_config/nvim/lua/workflow/**"],
      "providerIDs": ["df:provider/lua-lsp", "df:provider/cue-rg"]
    },
    "dotfiles.xplr-sidebar": {
      "authority": "lua-implementation",
      "files": ["chezmoi/private_dot_config/xplr/init.lua"],
      "providerIDs": ["df:provider/lua-lsp", "df:provider/cue-rg"]
    },
    "dotfiles.manifest-slice": {
      "authority": "cue-graph",
      "files": [".github/dotfiles-manifest-slice/contracts/issues/**"],
      "providerIDs": ["df:provider/cue-lsp", "df:provider/codex-cli", "df:provider/cue-rg"]
    }
  },
  "mcpExecutionPolicy": {
    "providersReachable": true,
    "hookMayExecuteProviders": false,
    "providerOutputIsContext": false,
    "providerOutputIsAuthority": false,
    "requiresEvidenceWrapper": true,
    "routeDeclaredFilesOnly": true
  },
  "executionPolicy": {
    "providerOutputIsContext": false,
    "providerOutputIsAuthority": false,
    "hookMayExecuteProviders": false
  }
}
